---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SectionScrollNav from '../components/SectionScrollNav.vue';
import Footer from '../components/Footer.astro';
---

<Layout title="Apply for an Invite - ARTHAM AI Summit">
  <Header />
  <SectionScrollNav client:load />
  <main class="invite-page">
    <div class="invite-page-video-bg" aria-hidden="true">
      <iframe
        class="invite-page-video"
        src="https://www.youtube.com/embed/srQwyArPnP8?autoplay=1&mute=1&loop=1&playlist=srQwyArPnP8&controls=0&showinfo=0&modestbranding=1&iv_load_policy=3&rel=0"
        title="Invite background video"
        loading="eager"
        allow="autoplay; encrypted-media; picture-in-picture"
        referrerpolicy="strict-origin-when-cross-origin"
      ></iframe>
      <div class="invite-page-video-overlay"></div>
    </div>

    <section class="invite-hero">
      <div class="invite-container">
        <h1 class="invite-main-title">GET ON<br />THE LIST</h1>
      </div>
    </section>

    <section class="invite-form-section">
      <div class="invite-container">
        <div class="invite-form-wrapper">
          <div class="invite-form-content">
            <div class="invite-form-text">
              <p class="invite-edition">2026 Edition</p>
              <h2 class="invite-form-title">Apply for an Invite</h2>
              <p class="invite-form-description">
                To purchase an onsite ticket, we'll review your LinkedIn profile to confirm you meet the following criteria:
              </p>

              <ul class="invite-criteria">
                <li>
                  <svg class="criteria-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  A background in a design-related discipline
                </li>
                <li>
                  <svg class="criteria-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  A Senior-level title or above, or 5+ years of experience
                </li>
              </ul>

              <p class="invite-form-note">
                If you don't meet the criteria, online tickets are available to everyone.
              </p>
              <p class="invite-form-hint">Lost your code? Complete the application again and it will be automatically retrieved.</p>
            </div>

            <form class="invite-form" id="inviteForm">
              <div class="form-row">
                <label class="form-field">
                  <span class="field-label">First Name<span class="field-required">(required)</span></span>
                  <input type="text" name="firstName" placeholder="" required />
                </label>
                <label class="form-field">
                  <span class="field-label">Last Name<span class="field-required">(required)</span></span>
                  <input type="text" name="lastName" placeholder="" required />
                </label>
              </div>

              <div class="form-row">
                <label class="form-field">
                  <span class="field-label">Company</span>
                  <input type="text" name="company" placeholder="" />
                </label>
                <label class="form-field">
                  <span class="field-label">Email<span class="field-required">(required)</span></span>
                  <input type="email" name="email" placeholder="" required />
                </label>
              </div>

              <div class="form-row">
                <label class="form-field">
                  <span class="field-label">Country<span class="field-required">(required)</span></span>
                  <select name="country" required>
                    <option value="">Select a country...</option>
                    <option value="DE">Germany</option>
                    <option value="US">United States</option>
                    <option value="GB">United Kingdom</option>
                    <option value="FR">France</option>
                    <option value="NL">Netherlands</option>
                    <option value="other">Other</option>
                  </select>
                </label>
                <label class="form-field">
                  <span class="field-label">LinkedIn URL<span class="field-required">(required)</span></span>
                  <input type="url" name="linkedinUrl" placeholder="" required />
                </label>
              </div>

              <div class="form-consent">
                <label class="consent-checkbox">
                  <input type="checkbox" name="privacy" required />
                  <span>I agree to the <a href="#" class="consent-link">Privacy Policy</a> and to be contacted by the organizers about this and future events</span>
                </label>
              </div>

              <button type="submit" class="form-submit">Send Application</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
.invite-page {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #0f1419 0%, #1a2332 50%, #0d1620 100%);
  color: #D9D5C4;
  min-height: 100vh;
  margin-top: -76px;
  padding-top: 76px;
}

.invite-page-video-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.invite-page-video {
  width: 100%;
  height: 100%;
  border: 0;
  transform: scale(1.22);
  transform-origin: center center;
  pointer-events: none;
  filter: saturate(1.05) contrast(1.02) brightness(0.95);
}

.invite-page-video-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(7, 11, 18, 0.5) 0%, rgba(10, 16, 24, 0.36) 36%, rgba(10, 16, 24, 0.58) 100%),
    radial-gradient(ellipse at 52% 42%, rgba(255, 79, 18, 0.2) 0%, rgba(255, 79, 18, 0.1) 38%, transparent 70%),
    linear-gradient(90deg, rgba(4, 8, 14, 0.28) 0%, transparent 24%, transparent 76%, rgba(4, 8, 14, 0.28) 100%);
}

.invite-hero {
  position: relative;
  margin-top: 0;
  padding: 7rem 1rem 2.5rem;
  text-align: center;
  background: transparent;
  z-index: 1;
}

.invite-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.invite-main-title {
  font-size: clamp(3rem, 8vw, 3.5rem);
  font-weight: 300;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin: 0;
  text-transform: uppercase;
}

.invite-form-section {
  padding: 0.75rem 1rem 4rem;
  margin-top: 0;
  position: relative;
  z-index: 1;
}

.invite-form-wrapper {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  border-radius: 6px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  color: #1a2332;
}

.invite-form-content {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 0;
}

.invite-form-text {
  padding: 2.5rem 2.5rem;
  border-right: 1px solid #efefef;
}

.invite-form-header {
  padding: 2.5rem 2.5rem;
  border-bottom: 1px solid #efefef;
}

.invite-edition {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #888;
  margin: 0 0 0.8rem 0;
  font-weight: 600;
}

.invite-form-title {
  font-size: 1.6rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
  color: #1a2332;
}

.invite-form-description {
  font-size: 0.9rem;
  color: #555;
  margin: 0 0 1.2rem 0;
  line-height: 1.6;
}

.invite-criteria {
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem 0;
}

.invite-criteria li {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.95rem;
  color: #333;
  margin-bottom: 0.8rem;
  line-height: 1.5;
}

.criteria-check {
  width: 20px;
  height: 20px;
  color: #22c55e;
  flex-shrink: 0;
  margin-top: 2px;
}

.invite-form-note {
  font-size: 0.9rem;
  color: #666;
  margin: 0 0 0.8rem 0;
  line-height: 1.5;
}

.invite-form-hint {
  font-size: 0.85rem;
  color: #e74c3c;
  margin: 0;
  line-height: 1.5;
}

.invite-form {
  padding: 2.5rem 2.5rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-bottom: 1.5rem;
}

@media (max-width: 600px) {
  .form-row {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}

.form-field {
  display: flex;
  flex-direction: column;
}

.field-label {
  font-size: 0.8rem;
  font-weight: 500;
  color: #1a2332;
  margin-bottom: 0.6rem;
  text-transform: capitalize;
  display: block;
  letter-spacing: 0.3px;
}

.field-required {
  font-size: 0.8rem;
  font-weight: 400;
  color: #999;
}

.form-field input,
.form-field select {
  padding: 0.7rem 1rem;
  border: 1.5px solid #e0e0e0;
  border-radius: 5px;
  font-size: 0.9rem;
  font-family: inherit;
  background: #ffffff;
  color: #1a2332;
  transition: all 0.3s ease;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
}

.form-field input::placeholder {
  color: #d0d0d0;
}

.form-field input:hover,
.form-field select:hover {
  border-color: #d0d0d0;
  box-shadow: 0 3px 8px rgba(0, 0, 0, 0.06);
}

.form-field input:focus,
.form-field select:focus {
  outline: none;
  border-color: #555;
  background: #ffffff;
  box-shadow: 0 0 0 3px rgba(85, 85, 85, 0.08), 0 4px 12px rgba(0, 0, 0, 0.08);
}

.form-field select {
  cursor: pointer;
  appearance: none;
  background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3E%3Cpath stroke='%236B7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3E%3C/svg%3E");
  background-position: right 0.75rem center;
  background-repeat: no-repeat;
  background-size: 1.5em 1.5em;
  padding-right: 2.4rem;
}

.form-consent {
  margin: 2.5rem 0;
  padding: 1.5rem 1.25rem;
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
  border: 1px solid #e8eaed;
  border-radius: 5px;
  transition: all 0.3s ease;
}

.form-consent:hover {
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaed 100%);
  border-color: #dfe1e5;
}

.consent-checkbox {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.85rem;
  color: #333;
  line-height: 1.6;
  cursor: pointer;
}

.consent-checkbox input {
  width: 18px;
  height: 18px;
  margin-top: 2px;
  flex-shrink: 0;
  cursor: pointer;
  accent-color: #555;
  border: 1.5px solid #d0d0d0;
  border-radius: 3px;
  transition: all 0.2s ease;
}

.consent-checkbox input:hover {
  border-color: #555;
  box-shadow: 0 0 0 2px rgba(85, 85, 85, 0.1);
}

.consent-checkbox input:checked {
  background: #555;
  border-color: #555;
}

.consent-link {
  color: #B5621A;
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s ease;
}

.consent-link:hover {
  color: #e63f0c;
  text-decoration: underline;
}

.form-submit {
  width: auto;
  padding: 0.95rem 2.5rem;
  background: linear-gradient(135deg, #555 0%, #444 100%);
  color: white;
  border: none;
  border-radius: 5px;
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.3px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(85, 85, 85, 0.2);
  text-transform: capitalize;
}

.form-submit:hover {
  background: linear-gradient(135deg, #444 0%, #333 100%);
  box-shadow: 0 6px 16px rgba(85, 85, 85, 0.3);
  transform: translateY(-1px);
}

.form-submit:active {
  transform: translateY(0);
  box-shadow: 0 2px 8px rgba(85, 85, 85, 0.2);
}

@media (max-width: 768px) {
  .invite-hero {
    padding: 5rem 1rem;
  }

  .invite-main-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  .invite-form-section {
    padding: 2rem 1rem;
  }

  .invite-form-wrapper {
    border-radius: 8px;
  }

  .invite-form-content {
    grid-template-columns: 1fr;
  }

  .invite-form-text {
    padding: 1.5rem;
    border-right: none;
    border-bottom: 1px solid #efefef;
  }

  .invite-form {
    padding: 1.5rem;
  }
}
</style>
