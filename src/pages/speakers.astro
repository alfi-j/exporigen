---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Speaker = {
  name: string;
  role: string;
  company: string;
  image: string;
};

const speakers: Speaker[] = [
  {
    name: 'Rachel Kobetz',
    role: 'Chief AI Experience Officer',
    company: 'OpenAI',
    image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Randy Hunt',
    role: 'Head of AI Product',
    company: 'Notion',
    image: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Paula Scher',
    role: 'AI Strategy Partner',
    company: 'Anthropic',
    image: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Nicole Michaelis',
    role: 'Director of AI Platforms',
    company: 'Vercel',
    image: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Mehmet Aydin Baytas',
    role: 'AI Interface Engineer',
    company: 'Stripe',
    image: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Maria Cortes Puch',
    role: 'VP, Responsible AI Programs',
    company: 'Linear',
    image: 'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Jason Wild',
    role: 'VP, AI Product Innovation',
    company: 'PayPal',
    image: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&w=1200&q=90',
  },
  {
    name: 'Alexandra Goncalves',
    role: 'VP, Applied AI in Health',
    company: 'Figma',
    image: 'https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=1200&q=90',
  },
];
---

<Layout title="Expositores - EXPORIGEN">
  <Header links={speakerLinks} />

  <main class="speakers-page">
    <section class="speakers-hero">
      <div class="container speakers-hero-inner">
        <p class="eyebrow">ARTHAM AI Summit 2026</p>
        <h1>All Speakers</h1>
        <p>
          Explore the full lineup of product, engineering, and design leaders sharing real-world AI outcomes.
        </p>
      </div>
    </section>

    <section class="speakers-grid-section" aria-label="All event speakers">
      <div class="container speakers-grid">
        {speakers.map((speaker) => (
          <article class="speaker-card">
            <div class="speaker-photo">
              <img src={speaker.image} alt={speaker.name} loading="lazy" />
            </div>
            <div class="speaker-content">
              <h2>{speaker.name}</h2>
              <p class="speaker-role">{speaker.role}</p>
              <p class="speaker-company">{speaker.company}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.speakers-page {
  background: #f7f6f4;
  min-height: 100vh;
}

.speakers-hero {
  padding: 7.2rem 0 2.2rem;
}

.speakers-hero-inner {
  width: min(1120px, 94%);
}

.eyebrow {
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 0.78rem;
  font-weight: 700;
  color: #6a7278;
}

.speakers-hero h1 {
  margin: 0.45rem 0 0;
  font-size: clamp(2.3rem, 6vw, 4.5rem);
  line-height: 0.94;
  letter-spacing: -0.03em;
  color: #1f2429;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
}

.speakers-hero p {
  margin: 0.95rem 0 0;
  max-width: 55ch;
  color: #343b41;
  font-size: clamp(1rem, 1.25vw, 1.14rem);
  line-height: 1.55;
}

.speakers-grid-section {
  padding: 0 0 4.6rem;
}

.speakers-grid {
  width: min(1120px, 94%);
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.1rem;
}

.speaker-card {
  border-radius: 14px;
  border: 1px solid #dcdbe0;
  background: #fcfcfc;
  overflow: hidden;
  box-shadow: 0 8px 18px rgba(19, 25, 38, 0.05);
}

.speaker-photo {
  background: #e5e6ea;
}

.speaker-photo img {
  display: block;
  width: 100%;
  aspect-ratio: 1.08;
  object-fit: cover;
}

.speaker-content {
  padding: 0.9rem;
}

.speaker-content h2 {
  margin: 0;
  font-size: 1.08rem;
  line-height: 1.2;
  color: #20242a;
}

.speaker-role {
  margin: 0.38rem 0 0;
  color: #3f464d;
  font-size: 0.9rem;
  line-height: 1.4;
}

.speaker-company {
  margin: 0.52rem 0 0;
  color: #f04f15;
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

@media (max-width: 1100px) {
  .speakers-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 820px) {
  .speakers-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  .speakers-hero {
    padding-top: 6.3rem;
  }

  .speakers-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}
</style>
