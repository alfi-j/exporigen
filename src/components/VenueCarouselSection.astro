---
const slides = [
  {
    image:
      'https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&w=1800&q=80',
    alt: 'Centro de exposiciones EXPORIGEN',
  },
  {
    image:
      'https://images.unsplash.com/photo-1505373877841-8d25f7d46678?auto=format&fit=crop&w=1800&q=80',
    alt: 'Área de stands exteriores',
  },
  {
    image:
      'https://images.unsplash.com/photo-1475721027785-f74eccf877e2?auto=format&fit=crop&w=1800&q=80',
    alt: 'Zona de eventos y actividades',
  },
  {
    image:
      'https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=1800&q=80',
    alt: 'Visitas familiares a la feria',
  },
];
---

<section class="venue-section" id="venue" aria-labelledby="venue-title">
  <div class="venue-fullbleed" data-venue-carousel>
    <div class="venue-slides" aria-live="polite">
      {slides.map((slide, index) => (
        <figure
          class:list={["venue-slide", index === 0 && "is-active"]}
          style={`--bg:url('${slide.image}')`}
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          <span class="sr-only">{slide.alt}</span>
        </figure>
      ))}
    </div>

    <aside class="venue-card" aria-labelledby="venue-title">
      <p class="kicker">La Sede</p>
      <h2 id="venue-title">Centro de Ferias EXPORIGEN</h2>
      <p class="copy">
        El centro de exposiciones de Santo Domingo de los Colorados. Espacios cubiertos y al aire libre,
        con capacidad para más de 80 expositors y 5,000 visitantes.
      </p>
      <p class="address-title">Av. Quito</p>
      <p class="address-sub">Santo Domingo, Ecuador</p>
      <a
        class="maps-link"
        href="https://maps.google.com/?q=Santo+Domingo+de+los+Colorados+Ecuador"
        target="_blank"
        rel="noopener noreferrer"
      >
        Ver en Maps ->
      </a>
    </aside>

    <div class="venue-dots" role="tablist" aria-label="Venue slides">
      {slides.map((_, index) => (
        <button class:list={["dot", index === 0 && "is-active"]} type="button" aria-label={`Go to slide ${index + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-venue-carousel]');
    if (!root) return;

    const slides = Array.from(root.querySelectorAll('.venue-slide'));
    const dots = Array.from(root.querySelectorAll('.dot'));
    let current = 0;
    let timer;

    const apply = (idx) => {
      slides.forEach((slide, i) => {
        const active = i === idx;
        slide.classList.toggle('is-active', active);
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === idx));
      current = idx;
    };

    const next = () => apply((current + 1) % slides.length);

    const start = () => {
      stop();
      timer = setInterval(next, 4200);
    };

    const stop = () => {
      if (timer) clearInterval(timer);
    };

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        apply(i);
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    start();
  })();
</script>

<style>
.venue-section {
  background: #ececec;
  padding: 0;
}

.venue-fullbleed {
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  min-height: 100vh;
  height: 100vh;
  overflow: hidden;
}

.venue-slides {
  position: absolute;
  inset: 0;
}

.venue-slide {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(180deg, rgba(10, 15, 19, 0.2), rgba(10, 15, 19, 0.15)), var(--bg);
  background-size: cover;
  background-position: center;
  opacity: 0;
  transform: scale(1.04);
  transition: opacity 900ms ease, transform 5200ms ease;
}

.venue-slide.is-active {
  opacity: 1;
  transform: scale(1);
}

.venue-card {
  position: absolute;
  z-index: 3;
  right: clamp(1rem, 4vw, 4rem);
  top: 52%;
  transform: translateY(-50%);
  width: min(410px, calc(100% - 2rem));
  border-radius: 24px;
  padding: 1.25rem 1.25rem 1rem;
  background: rgba(245, 245, 246, 0.95);
  box-shadow: 0 16px 48px rgba(6, 9, 12, 0.18);
}

.kicker {
  margin: 0;
  color: #777f87;
  font-size: 2rem;
  line-height: 1;
}

.venue-card h2 {
  margin: 0.2rem 0 0;
  color: #1e252b;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-size: clamp(2rem, 2.4vw, 2.65rem);
  line-height: 0.95;
}

.copy {
  margin: 0.8rem 0 0;
  color: #4a4a4a;
  font-size: 1rem;
  line-height: 1.45;
}

.address-title {
  margin: 0.9rem 0 0;
  padding-top: 0.8rem;
  border-top: 1px dashed #c8cbcf;
  color: #232b31;
  font-weight: 700;
}

.address-sub {
  margin: 0.15rem 0 0;
  color: #5d6871;
}

.maps-link {
  margin-top: 0.95rem;
  width: 100%;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  border-radius: 999px;
  min-height: 46px;
  background: #B5621A;
  color: #fff;
  font-weight: 700;
  text-decoration: none;
}

.venue-dots {
  position: absolute;
  left: 50%;
  bottom: 0.95rem;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  gap: 0.42rem;
}

.dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  border: 0;
  background: rgba(255, 255, 255, 0.65);
  cursor: pointer;
}

.dot.is-active {
  background: #fff;
  transform: scale(1.2);
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

@media (max-width: 900px) {
  .venue-fullbleed {
    min-height: auto;
    height: clamp(620px, 92vh, 840px);
  }

  .venue-card {
    position: relative;
    right: auto;
    top: auto;
    transform: none;
    margin: 9.5rem auto 2.5rem;
  }

}

@media (max-width: 680px) {
  .venue-fullbleed {
    height: 600px;
  }

  .venue-card {
    width: calc(100% - 1.1rem);
    margin-top: 10.4rem;
  }

  .venue-card h2 {
    font-size: 1.85rem;
  }

  .copy {
    font-size: 0.95rem;
  }
}
</style>
