---
const categories = [
  { name: 'Gastronomía', icon: '🍽️' },
  { name: 'Artesanía', icon: '🧵' },
  { name: 'Agroproductos', icon: '🌾' },
  { name: 'Innovación', icon: '💡' },
  { name: 'Arte & Cultura', icon: '🎨' },
];

const featuredExhibitors = [
  { name: 'Café La Esperanza', category: 'Agroproductos' },
  { name: 'Manos Tsáchilas', category: 'Artesanía' },
  { name: 'Sabores del Valle', category: 'Gastronomía' },
];

const aftermovieYouTubeId = 'srQwyArPnP8';
const aftermovieEmbedUrl = `https://www.youtube.com/embed/${aftermovieYouTubeId}?autoplay=1&mute=1&loop=1&playlist=${aftermovieYouTubeId}&controls=1&modestbranding=1&rel=0`;
const aftermovieWatchUrl = `https://www.youtube.com/watch?v=${aftermovieYouTubeId}`;
---

<section class="noise-stage" id="lineup" aria-labelledby="noise-stage-title">
  <div class="noise-shell container">
    <span class="noise-kicker reveal-line" style="--reveal-delay: 0s;">Emprendedores Locales</span>
    <h2 id="noise-stage-title" class="noise-title reveal-line" style="--reveal-delay: 0.12s;">
      Descubre lo Mejor de
      <span>Santo Domingo</span>
    </h2>
    <p class="noise-copy reveal-line" style="--reveal-delay: 0.24s;">
      Conoce a los empresarios locales que bringen productos únicos y servicios de calidad a nuestra comunidad.
    </p>

    <article class="video-card" aria-label="Aftermovie teaser">
      <iframe
        class="video-frame"
        src={aftermovieEmbedUrl}
        title="Feria expo aftermovie"
        loading="lazy"
        aria-label="Feria expo aftermovie"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
      <a class="video-pill" href={aftermovieWatchUrl} target="_blank" rel="noopener noreferrer" aria-label="Ver momentos de la feria en YouTube">Ver Highlights 2025</a>
    </article>

    <section class="brand-showcase" aria-labelledby="brand-showcase-title">
      <p id="brand-showcase-title" class="brand-note reveal-line" style="--reveal-delay: 0.36s;">Categorías en EXPORIGEN</p>

      <div class="brand-row reveal-line" style="--reveal-delay: 0.48s;">
        {
          categories.map((cat, index) => (
            <span
              class="brand-icon"
              aria-label={cat.name}
              title={cat.name}
              style={`--brand-tone: #B5621A; --icon-delay: ${0.74 + index * 0.08}s;`}
            >
              <span class="brand-fallback">{cat.icon}</span>
            </span>
          ))
        }
      </div>

      <div class="brand-row brand-row-subtle reveal-line" style="--reveal-delay: 0.58s;">
        {
          featuredExhibitors.map((exhibitor, index) => (
            <span
              class="brand-icon"
              aria-label={exhibitor.name}
              title={exhibitor.name}
              style={`--brand-tone: #1f2f14; --icon-delay: ${1.1 + index * 0.08}s;`}
            >
              <span class="brand-fallback" style="font-size: 0.6rem;">{exhibitor.name.charAt(0)}</span>
            </span>
          ))
        }
        <span class="brand-icon brand-icon-more" aria-label="Y más expositors" style="--icon-delay: 1.36s;">+</span>
      </div>
    </section>
  </div>

  <div class="decor decor-left" aria-hidden="true"></div>
  <div class="decor decor-right" aria-hidden="true"></div>
  <div class="cross cross-left" aria-hidden="true"></div>
  <div class="cross cross-right" aria-hidden="true"></div>
  <div class="noise-dot noise-dot-a" aria-hidden="true"></div>
  <div class="noise-dot noise-dot-b" aria-hidden="true"></div>
  <div class="noise-arc noise-arc-a" aria-hidden="true"></div>
  <div class="noise-arc noise-arc-b" aria-hidden="true"></div>
</section>

<script>
  const noiseStage = document.querySelector('.noise-stage');
  const videoEl = document.querySelector('video.js-noise-video');

  if (noiseStage) {
    const stageObserver = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          noiseStage.classList.add('is-visible');
        }
      },
      { threshold: 0.25 }
    );

    stageObserver.observe(noiseStage);
  }

  if (videoEl) {
    const tryPlay = () => {
      const playPromise = videoEl.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {
          // Ignore autoplay rejections silently.
        });
      }
    };

    videoEl.muted = true;
    videoEl.defaultMuted = true;
    videoEl.playsInline = true;

    const retryPlay = () => {
      if (!videoEl.paused) return;
      tryPlay();
      window.setTimeout(() => {
        if (videoEl.paused) tryPlay();
      }, 350);
    };

    videoEl.addEventListener('loadeddata', retryPlay);
    videoEl.addEventListener('canplay', retryPlay);
    videoEl.addEventListener('mouseenter', tryPlay);

    tryPlay();
    window.requestAnimationFrame(tryPlay);
    window.setTimeout(tryPlay, 250);

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          retryPlay();
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );

    observer.observe(videoEl);
  }
</script>

<style>
.noise-stage {
  position: relative;
  overflow: hidden;
  background-color: #1f2f14;
  background-image: linear-gradient(180deg, #1f2f14 0%, #324d1f 42%, #0c140a 100%);
  background-size: 130% 130%;
  color: #D9D5C4;
  margin-top: -340px;
  padding: 260px 0 3.8rem;
  clip-path: polygon(
    0 16%,
    8% 14%,
    22% 12%,
    36% 10%,
    50% 9%,
    64% 10%,
    78% 12%,
    92% 14%,
    100% 16%,
    100% 100%,
    0 100%
  );
  animation: gradient-shift 12.9s ease-in-out infinite alternate;
}

.noise-shell {
  position: relative;
  z-index: 2;
  padding-top: 5.6rem;
  text-align: center;
  width: 100%;
}

.noise-kicker {
  text-transform: uppercase;
  letter-spacing: 0.3em;
  font-size: 0.88rem;
  color: #a0a0a0;
  font-weight: 700;
}

.noise-title {
  margin: 0.7rem auto 0;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-size: clamp(2rem, 5vw, 3.7rem);
  line-height: 1.02;
  text-transform: uppercase;
  font-weight: 500;
  max-width: 15ch;
}

.noise-title span {
  color: #B5621A;
}

.noise-copy {
  margin: 0.85rem auto 0;
  font-size: clamp(1rem, 1.55vw, 1.75rem);
  color: #a0a0a0;
  max-width: 45ch;
}

.video-card {
  margin: 1.6rem auto 0;
  max-width: min(920px, 92%);
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
  background: rgba(0, 0, 0, 0.3);
  padding: 0.6rem;
  position: relative;
}

.video-frame {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 9;
  border: 0;
}

.video-pill {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  background: rgba(17, 17, 17, 0.86);
  color: #fff;
  text-decoration: none;
  border-radius: 999px;
  padding: 0.72rem 1.2rem;
  font-weight: 700;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.26);
}

.reveal-line {
  opacity: 0;
  transform: translate3d(0, 18px, 0);
  filter: blur(8px);
  transition:
    opacity 0.8s ease,
    transform 0.8s cubic-bezier(0.2, 0.75, 0.2, 1),
    filter 0.8s ease;
  transition-delay: var(--reveal-delay, 0s);
  will-change: opacity, transform, filter;
}

.noise-stage.is-visible .reveal-line {
  opacity: 1;
  transform: translate3d(0, 0, 0);
  filter: blur(0);
}

.brand-note {
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 2rem;
  color: #d7dce0;
  font-weight: 700;
}

.brand-showcase {
  position: relative;
  margin: 3.2rem auto 0;
  padding: 1.1rem 0 0.25rem;
  max-width: 980px;
}

.brand-showcase::before {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -34px;
  transform: translateX(-50%);
  width: min(960px, 95vw);
  height: 320px;
  background: repeating-radial-gradient(
    ellipse at 50% 100%,
    rgba(186, 194, 201, 0.15) 0 1px,
    transparent 1px 20px
  );
  opacity: 0.42;
  pointer-events: none;
}

.brand-row {
  margin-top: 1.55rem;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
  color: #f4f7fa;
  font-weight: 700;
  font-size: clamp(1.05rem, 1.9vw, 2rem);
  letter-spacing: 0.01em;
  position: relative;
  z-index: 1;
}

.brand-icon {
  width: 56px;
  height: 56px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: linear-gradient(160deg, color-mix(in srgb, var(--brand-tone, #1f2f14) 52%, #0c140a 48%), rgba(12, 20, 10, 0.92));
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  opacity: 0;
  transform: translate3d(0, 14px, 0) scale(0.82);
  filter: blur(6px);
  will-change: transform, opacity, filter;
  transition:
    transform 0.26s cubic-bezier(0.2, 0.8, 0.2, 1),
    box-shadow 0.26s ease,
    border-color 0.26s ease,
    background 0.26s ease;
}

.noise-stage.is-visible .brand-icon {
  animation: icon-reveal 0.62s cubic-bezier(0.2, 0.78, 0.18, 1) forwards;
  animation-delay: var(--icon-delay, 0s);
}

.brand-icon:hover {
  transform: translate3d(0, -4px, 0) scale(1.06);
  border-color: color-mix(in srgb, var(--brand-tone, #7da6c6) 62%, #eef4f8 38%);
  box-shadow:
    0 8px 22px color-mix(in srgb, var(--brand-tone, #54718b) 42%, transparent 58%),
    inset 0 0 0 1px rgba(255, 255, 255, 0.14);
}

.brand-icon:hover .brand-logo,
.brand-icon:hover .brand-fallback,
.brand-icon:hover.brand-icon-more {
  transform: scale(1.08);
}

.brand-logo {
  width: 24px;
  height: 24px;
  color: #eef4f8;
  transition: transform 0.26s ease;
}

.brand-logo :global(svg) {
  width: 100%;
  height: 100%;
  display: block;
  fill: currentColor;
}

.brand-fallback {
  font-size: 0.75rem;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0.06em;
  color: #ecf3f7;
  text-transform: uppercase;
  transition: transform 0.26s ease;
}

.brand-icon-more {
  font-size: 1.7rem;
  line-height: 1;
  color: #f4f7fa;
  font-weight: 600;
}

.brand-row-subtle {
  margin-top: 1rem;
  color: #cfd7dd;
  font-size: clamp(0.95rem, 1.55vw, 1.6rem);
}

.decor {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  z-index: 1;
}

.decor-left {
  width: 500px;
  height: 500px;
  border: 26px solid rgba(255, 74, 17, 0.75);
  left: -260px;
  top: 370px;
  box-shadow:
    inset 0 0 0 10px rgba(255, 255, 255, 0.74),
    inset 0 0 0 44px rgba(0, 0, 0, 0.4);
  animation: float-left 6.4s ease-in-out infinite;
}

.decor-right {
  width: 580px;
  height: 580px;
  border: 38px solid rgba(255, 74, 17, 0.74);
  right: -200px;
  top: 150px;
  box-shadow: inset 0 0 0 10px rgba(255, 255, 255, 0.28);
  animation: float-right 7.9s ease-in-out infinite;
}

.cross {
  position: absolute;
  width: 95px;
  height: 95px;
  opacity: 0.6;
  z-index: 1;
}

.cross::before,
.cross::after {
  content: "";
  position: absolute;
  background: rgba(255, 74, 17, 0.72);
}

.cross::before {
  width: 2px;
  height: 100%;
  left: 50%;
  top: 0;
}

.cross::after {
  height: 2px;
  width: 100%;
  top: 50%;
  left: 0;
}

.cross-left {
  left: 50px;
  bottom: 120px;
  animation: cross-pulse 3.3s ease-in-out infinite;
}

.cross-right {
  right: 70px;
  top: 260px;
  animation: cross-pulse 3.7s ease-in-out infinite;
}

.noise-dot {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  z-index: 1;
}

.noise-dot-a {
  width: 18px;
  height: 18px;
  left: 22%;
  top: 190px;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 0 0 10px rgba(255, 79, 18, 0.18);
  animation: dot-bob 3.6s ease-in-out infinite;
}

.noise-dot-b {
  width: 28px;
  height: 28px;
  right: 19%;
  bottom: 170px;
  background: rgba(255, 79, 18, 0.9);
  box-shadow: 0 0 0 12px rgba(255, 255, 255, 0.08);
  animation: dot-bob 4.3s ease-in-out infinite reverse;
}

.noise-arc {
  position: absolute;
  pointer-events: none;
  z-index: 1;
  border: 3px solid rgba(255, 255, 255, 0.22);
  border-radius: 999px;
}

.noise-arc-a {
  width: 180px;
  height: 180px;
  right: 24%;
  top: 120px;
  border-left-color: transparent;
  border-bottom-color: transparent;
  transform: rotate(14deg);
  animation: arc-sway 5.6s ease-in-out infinite;
}

.noise-arc-b {
  width: 120px;
  height: 120px;
  left: 10%;
  bottom: 90px;
  border-right-color: transparent;
  border-top-color: transparent;
  transform: rotate(-18deg);
  opacity: 0.45;
  animation: arc-sway 5s ease-in-out infinite reverse;
}

@keyframes gradient-shift {
  0% {
    background-position: 0% 35%;
  }

  100% {
    background-position: 100% 65%;
  }
}

@keyframes float-left {
  0%,
  100% {
    transform: translate3d(0, 0, 0) rotate(0deg);
  }

  50% {
    transform: translate3d(10px, -10px, 0) rotate(2deg);
  }
}

@keyframes float-right {
  0%,
  100% {
    transform: translate3d(0, 0, 0) rotate(0deg);
  }

  50% {
    transform: translate3d(-12px, 12px, 0) rotate(-2deg);
  }
}

@keyframes cross-pulse {
  0%,
  100% {
    opacity: 0.45;
    transform: scale(1);
  }

  50% {
    opacity: 0.85;
    transform: scale(1.06);
  }
}

@keyframes dot-bob {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }

  50% {
    transform: translate3d(0, -10px, 0) scale(1.08);
  }
}

@keyframes arc-sway {
  0%,
  100% {
    transform: translate3d(0, 0, 0) rotate(14deg);
  }

  50% {
    transform: translate3d(0, -8px, 0) rotate(8deg);
  }
}

@keyframes icon-reveal {
  0% {
    opacity: 0;
    transform: translate3d(0, 14px, 0) scale(0.82);
    filter: blur(6px);
  }

  75% {
    opacity: 1;
    transform: translate3d(0, -2px, 0) scale(1.04);
    filter: blur(0);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }
}

@media (max-width: 900px) {
  .noise-stage {
    margin-top: -120px;
    padding-top: 120px;
    clip-path: polygon(
      0 14%,
      8% 12%,
      22% 10%,
      36% 8%,
      50% 7%,
      64% 8%,
      78% 10%,
      92% 12%,
      100% 14%,
      100% 100%,
      0 100%
    );
  }

  .noise-shell {
    padding-top: 4.6rem;
  }

  .decor-right {
    width: 360px;
    height: 360px;
    border-width: 24px;
    right: -140px;
    top: 260px;
  }

  .decor-left {
    width: 320px;
    height: 320px;
    border-width: 16px;
    left: -160px;
    top: 460px;
  }

  .brand-note {
    font-size: 1.3rem;
    letter-spacing: 0.14em;
  }

  .brand-row {
    gap: 1rem;
  }

  .brand-icon {
    width: 46px;
    height: 46px;
  }

  .brand-logo {
    width: 20px;
    height: 20px;
  }

  .brand-fallback {
    font-size: 0.66rem;
  }

  .noise-dot-a {
    left: 12%;
    top: 165px;
    width: 14px;
    height: 14px;
  }

  .noise-dot-b {
    right: 12%;
    bottom: 150px;
    width: 22px;
    height: 22px;
  }

  .noise-arc-a {
    width: 128px;
    height: 128px;
    right: 14%;
    top: 140px;
  }

  .noise-arc-b {
    width: 88px;
    height: 88px;
    left: 4%;
    bottom: 70px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .brand-icon {
    opacity: 1;
    transform: none;
    filter: none;
    animation: none !important;
    transition: none;
  }

  .brand-logo,
  .brand-fallback,
  .brand-icon-more {
    transition: none;
  }
}

@media (hover: none) {
  .brand-icon:hover {
    transform: none;
    border-color: rgba(255, 255, 255, 0.22);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
}
</style>
