---
const testimonials = [
  {
    name: 'María Elena García',
    role: 'Café La Esperanza',
    photo: 'https://randomuser.me/api/portraits/women/32.jpg',
    quote:
      'Participar en EXPORIGEN fue increíble. Nuestro café llegó a cientos de clientes nuevos que nunca habrían probado nuestros productos.',
  },
  {
    name: 'Carlos Andrés López',
    role: 'Manos Artesanales',
    photo: 'https://randomuser.me/api/portraits/men/76.jpg',
    quote:
      'La feria nos dio la oportunidad de mostrar nuestros textiles tradicionales. Las ventas superaron todas nuestras expectativas.',
  },
  {
    name: 'Ana Sofía Vargas',
    role: 'Frutas Tropicales SD',
    photo: 'https://randomuser.me/api/portraits/women/58.jpg',
    quote:
      'Como pequeños productores, encontrar un espacio así es invaluable. EXPORIGEN conecta el campo con la ciudad de manera directa.',
  },
  {
    name: 'Roberto Mejía',
    role: 'Panadería Artesanal',
    photo: 'https://randomuser.me/api/portraits/men/65.jpg',
    quote:
      'Fue nuestra primera vez como expositors y quedamos asombrados. Volveremos seguro el próximo año.',
  },
  {
    name: 'Laura Rodríguez',
    role: 'Arte Local',
    photo: 'https://randomuser.me/api/portraits/women/33.jpg',
    quote:
      'Pude dar a conocer mis pinturas a mucha gente que jamás habría llegado a mi taller. Esta experiencia cambió mi negocio.',
  },
  {
    name: 'Pedro Fuentes',
    role: 'Tech Santo Domingo',
    photo: 'https://randomuser.me/api/portraits/men/12.jpg',
    quote:
      'Excelente oportunidad para hacer networking con otros empresario y encontrar clientes para nuestros servicios.',
  },
];

const topRow = testimonials.slice(0, 3);
const bottomRow = testimonials.slice(3);
---

<section class="testimonials-section" id="testimonios" aria-labelledby="testimonials-title">
  <div class="testimonials-wrap">
    <h2 id="testimonials-title" class="testimonials-title">Lo que dicen nuestros expositors</h2>

    <div class="marquee-row">
      <div class="marquee-track marquee-track-forward">
        {[...topRow, ...topRow].map((item) => (
          <article class="testimonial-card">
            <p class="quote-mark" aria-hidden="true">“</p>
            <p class="quote">{item.quote}</p>

            <div class="person-row">
              <img src={item.photo} alt={item.name} loading="lazy" />
              <div>
                <p class="name">{item.name}</p>
                <p class="role">{item.role}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="marquee-row">
      <div class="marquee-track marquee-track-reverse">
        {[...bottomRow, ...bottomRow].map((item) => (
          <article class="testimonial-card">
            <p class="quote-mark" aria-hidden="true">“</p>
            <p class="quote">{item.quote}</p>

            <div class="person-row">
              <img src={item.photo} alt={item.name} loading="lazy" />
              <div>
                <p class="name">{item.name}</p>
                <p class="role">{item.role}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.testimonials-section {
  background: #f2f3f5;
  padding: 2.4rem 0 4.6rem;
}

.testimonials-wrap {
  width: 100%;
  display: grid;
  gap: 1rem;
}

.testimonials-title {
  margin: 0;
  text-align: center;
  color: #131a20;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-size: clamp(1.8rem, 3.2vw, 2.7rem);
  line-height: 1.04;
  letter-spacing: -0.018em;
}

.marquee-row {
  position: relative;
  overflow: hidden;
  padding-inline: 0.8rem;
}

.marquee-row::before,
.marquee-row::after {
  content: "";
  position: absolute;
  top: 0;
  width: 56px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.marquee-row::before {
  left: 0;
  background: linear-gradient(90deg, #f2f3f5, rgba(242, 243, 245, 0));
}

.marquee-row::after {
  right: 0;
  background: linear-gradient(270deg, #f2f3f5, rgba(242, 243, 245, 0));
}

.marquee-track {
  display: flex;
  gap: 0.9rem;
  width: max-content;
  will-change: transform;
}

.marquee-track-forward {
  animation: testimonials-left 24s linear infinite;
}

.marquee-track-reverse {
  animation: testimonials-left 24s linear infinite reverse;
}

.testimonial-card {
  width: clamp(260px, 30vw, 410px);
  min-height: 210px;
  background: #eceef2;
  border: 1px solid #e0e4ea;
  border-radius: 14px;
  padding: 1rem 1.05rem;
  color: #161d24;
  display: grid;
  grid-template-rows: auto 1fr auto;
}

.quote-mark {
  margin: 0;
  color: #B5621A;
  font-size: 2.8rem;
  line-height: 1;
  font-family: Georgia, "Times New Roman", serif;
}

.quote {
  margin: 0.2rem 0 0;
  font-size: 1.03rem;
  line-height: 1.42;
  color: #222a31;
}

.person-row {
  margin-top: 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.65rem;
}

.person-row img {
  width: 34px;
  height: 34px;
  border-radius: 999px;
  object-fit: cover;
}

.name {
  margin: 0;
  font-weight: 700;
  font-size: 1rem;
  line-height: 1.2;
}

.role {
  margin: 0.15rem 0 0;
  font-size: 0.8rem;
  color: #8a919a;
}

@keyframes testimonials-left {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(calc(-50% - 0.45rem));
  }
}

@media (max-width: 720px) {
  .testimonial-card {
    width: clamp(238px, 74vw, 320px);
    min-height: 200px;
  }

  .quote {
    font-size: 0.97rem;
  }

  .marquee-track-forward,
  .marquee-track-reverse {
    animation-duration: 28s;
  }
}

@media (prefers-reduced-motion: reduce) {
  .marquee-track-forward,
  .marquee-track-reverse {
    animation: none;
  }
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}
</style>
