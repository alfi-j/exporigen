<style>
  .hero-shell {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #F4F2EB;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(31, 47, 20, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(181, 98, 26, 0.06) 0%, transparent 50%),
      linear-gradient(180deg, #F4F2EB 0%, #EBE8E0 50%, #E2DED6 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background-image:
      repeating-linear-gradient(0deg, #1f2f14 0px, transparent 1px, transparent 60px, #1f2f14 61px),
      repeating-linear-gradient(90deg, #1f2f14 0px, transparent 1px, transparent 60px, #1f2f14 61px);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5vw;
    padding-top: 68px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    justify-content: center;
    padding-bottom: 4rem;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(244, 242, 235, 0.95);
    border: 1px solid rgba(31, 47, 20, 0.15);
    color: #1f2f14;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }

  .hero-logo {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.25rem;
    object-fit: contain;
    display: block;
  }

  .hero-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(4.5rem, 10vw, 10rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1em;
  }

  .hln-exp {
    color: #1f2f14;
  }

  .hln-origen {
    color: #B5621A;
  }

  .hero-subtitle {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: #3d4035;
    margin-top: 1.2rem;
    max-width: 520px;
    line-height: 1.6;
  }

  .hero-meta {
    display: flex;
    gap: 2.5rem;
    margin-top: 2.5rem;
    justify-content: center;
  }

  .hero-meta-item {
    text-align: center;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #476e22;
    display: block;
    margin-bottom: 0.2rem;
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 500;
    color: #1f2f14;
    display: block;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .cta-primary {
    background: #1f2f14;
    color: #fff;
  }

  .cta-primary:hover {
    background: #324d1f;
    transform: translateY(-2px);
  }

  .cta-arrow {
    width: 18px;
    height: 18px;
  }

  .cta-secondary {
    background: transparent;
    color: #1f2f14;
    border: 1px solid #1f2f14;
  }

  .cta-secondary:hover {
    background: rgba(31, 47, 20, 0.05);
    border-color: #324d1f;
  }

  .hero-marquee {
    overflow: hidden;
    line-height: 0;
    margin-bottom: -1px;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-slide 28s linear infinite;
  }

  .marquee-track img {
    width: clamp(230px, 19.6vw, 320px);
    height: 520px;
    object-fit: cover;
    object-position: center 32%;
    display: block;
  }

  @keyframes marquee-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (max-width: 900px) {
    .marquee-track img { height: 430px; }
  }

  @media (max-width: 640px) {
    .marquee-track img {
      width: 58vw;
      height: 340px;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .cta {
      width: 100%;
      text-align: center;
    }

    .hero-meta {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
</style>