---
---

<section class="hero-shell" id="inicio">
  <div class="hero-bg"></div>
  <div class="hero-pattern"></div>

  <div class="hero-content">
    <span class="hero-label">Santo Domingo de los Colorados · Ecuador</span>

    <h1 class="hero-title">
      <span class="hln-expo">EXPO</span><span class="hln-rigen">RIGEN</span>
    </h1>

    <p class="hero-subtitle">
      La feria que conecta emprendimientos autenticos con su comunidad. Gastronomia, artesania, innovacion y cultura — todo desde la raiz.
    </p>

    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="meta-label">Proxima Edicion</span>
        <span class="meta-value">Agosto 2025</span>
      </div>
      <div class="hero-meta-item">
        <span class="meta-label">Ubicacion</span>
        <span class="meta-value">Centro de Exposiciones</span>
      </div>
      <div class="hero-meta-item">
        <span class="meta-label">Entrada</span>
        <span class="meta-value">Libre al publico</span>
      </div>
    </div>

    <div class="hero-actions">
      <a href="#registro" class="cta cta-primary">Quiero ser expositor</a>
      <a href="#sobre" class="cta cta-secondary">Descubrir mas</a>
    </div>
  </div>

  
</section>

<style>
  .hero-shell {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0c140a;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 65% 45%, rgba(31, 47, 20, 0.9) 0%, transparent 70%),
      radial-gradient(ellipse 50% 70% at 15% 85%, rgba(19, 30, 13, 0.7) 0%, transparent 65%),
      linear-gradient(160deg, #0c140a 0%, #1a2812 45%, #0f1a0b 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image:
      repeating-linear-gradient(0deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px),
      repeating-linear-gradient(90deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5vw;
    padding-top: 68px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(31, 47, 20, 0.5);
    border: 1px solid rgba(181, 98, 26, 0.45);
    color: #D4783A;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }

  .hero-label::before {
    content: '';
    width: 20px;
    height: 1px;
    background: #B5621A;
  }

  .hero-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(4.5rem, 10vw, 10rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1em;
  }

  .hln-expo {
    color: #F4F2EB;
  }

  .hln-rigen {
    color: #B5621A;
  }

  .hero-subtitle {
    font-family: "Playfair Display", serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    color: #D9D5C4;
    margin-top: 1.2rem;
    max-width: 520px;
    line-height: 1.6;
  }

  .hero-meta {
    display: flex;
    gap: 2.5rem;
    margin-top: 2.5rem;
  }

  .hero-meta-item {
    text-align: center;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B5621A;
    display: block;
    margin-bottom: 0.2rem;
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 500;
    color: #F4F2EB;
    display: block;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .cta {
    padding: 0.85rem 2.2rem;
    font-family: "Barlow", sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta-primary {
    background: #B5621A;
    color: #0c140a;
  }

  .cta-primary:hover {
    background: #D4783A;
    transform: translateY(-2px);
  }

  .cta-secondary {
    background: transparent;
    color: #F4F2EB;
    border: 1.5px solid rgba(242, 232, 213, 0.45);
  }

  .cta-secondary:hover {
    border-color: #F4F2EB;
    transform: translateY(-2px);
  }

  

  

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .cta {
      width: 100%;
      text-align: center;
    }

    .hero-meta {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
</style>