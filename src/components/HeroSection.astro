    </div>
    <svg class="marquee-curve-bottom" viewBox="0 0 1440 220" preserveAspectRatio="none" role="presentation" aria-hidden="true">
      <path d="M0,220 L0,174 C320,112 1120,112 1440,174 L1440,220 Z"></path>
    </svg>
  </div>

  <script>
    (() => {
      const track = document.querySelector('.marquee-track');
      const shell = document.querySelector('.hero-shell');
      if (!track || !shell) return;
      let scrollTimeout;
      const handleScroll = () => {
        const rect = shell.getBoundingClientRect();
        if (rect.bottom > 0) {
          const distance = track.scrollWidth / 4;
          if (!distance) return;
          track.style.animation = 'none';
          const offset = ((window.scrollY * 0.5) % distance + distance) % distance;
          track.style.transform = `translateX(calc(-25% + ${offset}px))`;
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => {
            track.style.animation = '';
            track.style.transform = '';
          }, 1000);
        }
      };
      handleScroll();
      window.addEventListener('scroll', handleScroll, { passive: true });
    })();
  </script>

<style>
  .hero-shell {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0c140a;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 65% 45%, rgba(31, 47, 20, 0.9) 0%, transparent 70%),
      radial-gradient(ellipse 50% 70% at 15% 85%, rgba(19, 30, 13, 0.7) 0%, transparent 65%),
      linear-gradient(160deg, #0c140a 0%, #1a2812 45%, #0f1a0b 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image:
      repeating-linear-gradient(0deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px),
      repeating-linear-gradient(90deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5vw;
    padding-top: 68px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    justify-content: center;
    padding-bottom: 2.25rem;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(31, 47, 20, 0.5);
    border: 1px solid rgba(181, 98, 26, 0.45);
    color: #D4783A;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }

  .hero-label::before {
    content: '';
    width: 20px;
    height: 1px;
    background: #B5621A;
  }

  .hero-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(4.5rem, 10vw, 10rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1em;
  }

  .hln-expo {
    color: #F4F2EB;
  }

  .hln-rigen {
    color: #B5621A;
  }

  .hero-subtitle {
    font-family: "Playfair Display", serif;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    color: #D9D5C4;
    margin-top: 1.2rem;
    max-width: 520px;
    line-height: 1.6;
  }

  .hero-meta {
    display: flex;
    gap: 2.5rem;
    margin-top: 2.5rem;
  }

  .hero-meta-item {
    text-align: center;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B5621A;
    display: block;
    margin-bottom: 0.2rem;
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 500;
    color: #F4F2EB;
    display: block;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .cta-primary {
    background: #B5621A;
    color: #fff;
  }

  .cta-primary:hover {
    background: #D4783A;
    transform: translateY(-2px);
  }

  .cta-arrow {
    width: 18px;
    height: 18px;
  }

  .cta-secondary {
    background: transparent;
    color: #F4F2EB;
    border: 1px solid #D9D5C4;
  }

  .cta-secondary:hover {
    background: rgba(255, 252, 222, 0.1);
    border-color: #F4F2EB;
  }

  .hero-marquee {
    position: relative;
    overflow: hidden;
    background: transparent;
    z-index: 4;
    padding: 0;
    line-height: 0;
    margin-top: auto;
    margin-bottom: -74px;
    clip-path: polygon(
      0 0, 100% 0, 100% 89%, 92% 85%, 78% 81%, 64% 78%,
      50% 76.5%, 36% 78%, 22% 81%, 8% 85%, 0 89%
    );
  }

  .marquee-curve {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 136px;
    z-index: 2;
    pointer-events: none;
    mix-blend-mode: overlay;
    background-image:
      repeating-linear-gradient(0deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px),
      repeating-linear-gradient(90deg, #F4F2EB 0px, transparent 1px, transparent 60px, #F4F2EB 61px);
    opacity: 0.04;
  }

  .marquee-curve path { fill: #0c140a; }

  .marquee-curve-bottom {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 88px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-curve-bottom path { fill: #0c140a; }

  .marquee-track {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0;
    width: max-content;
    animation: marquee-slide 28s linear infinite;
  }

  .marquee-track img {
    width: clamp(230px, 19.6vw, 320px);
    height: 520px;
    object-fit: cover;
    object-position: center 32%;
    filter: saturate(1.02) contrast(1.02);
    display: block;
  }

  @keyframes marquee-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

@media (max-width: 900px) {
    .hero-marquee {
      margin-bottom: -48px;
      clip-path: polygon(
        0 0, 100% 0, 100% 91%, 92% 87%, 78% 83%, 64% 80%,
        50% 78.5%, 36% 80%, 22% 83%, 8% 87%, 0 91%
      );
    }

    .marquee-curve { height: 102px; }
    .marquee-curve-bottom { height: 88px; }

    .marquee-track img { height: 430px; }
  }

  @media (max-width: 640px) {
    .marquee-track img {
      width: 58vw;
      height: 340px;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }

    .cta {
      width: 100%;
      text-align: center;
    }

    .hero-meta {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
</style>