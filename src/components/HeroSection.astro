<section class="hero-shell" id="inicio">
  <div class="hero-bg"></div>
  <div class="hero-pattern"></div>

  <div class="hero-content">
    <span class="hero-label">Santo Domingo de los Colorados · Ecuador</span>

    <h1 class="hero-title">
      <span class="hln-expo">EXPO</span><span class="hln-rigen">RIGEN</span>
    </h1>

    <p class="hero-subtitle">
      La feria que conecta emprendimientos autenticos con su comunidad. Gastronomia, artesania, innovacion y cultura — todo desde la raiz.
    </p>

    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="meta-label">Proxima Edicion</span>
        <span class="meta-value">Agosto 2025</span>
      </div>
      <div class="hero-meta-item">
        <span class="meta-label">Ubicacion</span>
        <span class="meta-value">Centro de Exposiciones</span>
      </div>
      <div class="hero-meta-item">
        <span class="meta-label">Entrada</span>
        <span class="meta-value">Libre al publico</span>
      </div>
    </div>

    <div class="hero-actions">
      <a href="#registro" class="cta cta-primary">
        <span>Registrarme como Expositor</span>
        <svg class="cta-arrow" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M3 8h8M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>
      <a href="#sobre" class="cta cta-secondary">
        <span>Conocer Mas</span>
      </a>
    </div>
  </div>

  
</section>

  <div class="hero-marquee" aria-label="Feria moments">
    <svg class="marquee-curve" viewBox="0 0 1440 220" preserveAspectRatio="none" role="presentation" aria-hidden="true">
      <path d="M0,0 L0,46 C320,108 1120,108 1440,46 L1440,0 Z"></path>
    </svg>
    <div class="marquee-track">
      <img src="https://images.pexels.com/photos/18999161/pexels-photo-18999161.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Feria expo" loading="lazy" />
      <img src="https://images.pexels.com/photos/9275222/pexels-photo-9275222.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Feria expo" loading="lazy" />
