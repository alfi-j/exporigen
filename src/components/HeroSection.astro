        <svg class="cta-arrow" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M3 8h8M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>
      <a href="#sobre" class="cta cta-secondary">
        <span>Conocer Mas</span>
      </a>
    </div>
  </div>
</section>
