---

<section class="speakers-showcase" id="speakers" aria-labelledby="speakers-title">
  <div class="container speakers-wrap">
    <div class="section-head">
      <div class="section-copy">
        <h2 id="speakers-title">Expositores Destacados</h2>
        <p>Conoce a algunos de los empresario locales que participan en nuestras ferias. Cada uno trae productos unicos y servicios de calidad.</p>
      </div>
    </div>

    <div class="carousel-shell" data-speaker-carousel>
      <button class="carousel-nav carousel-nav-prev" type="button" data-dir="prev" aria-label="Previous exhibitors">
        <span aria-hidden="true">←</span>
      </button>

      <div class="speakers-viewport">
        <div class="speakers-track" data-speaker-track role="list" aria-label="Featured exhibitors">
          {exhibitors.map((exhibitor) => (
            <article class="speaker-card" role="listitem">
              <div class="portrait-wrap">
                <img src={exhibitor.image} alt={exhibitor.name} loading="lazy" />
              </div>

              <div class="card-meta">
                <h3>{exhibitor.name}</h3>
                <p class="role">{exhibitor.description}</p>

                <div class="company-row">
                  <span class="company-logo" aria-hidden="true">
                    {exhibitor.category.charAt(0)}
                  </span>
                  <span class="company-name">{exhibitor.category}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <button class="carousel-nav carousel-nav-next" type="button" data-dir="next" aria-label="Next exhibitors">
        <span aria-hidden="true">→</span>
      </button>
    </div>

    <a class="see-all-btn" href="#registro">Registrarme como Expositor →</a>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-speaker-carousel]');
    if (!root) return;

    const track = root.querySelector('[data-speaker-track]');
    const prevBtn = root.querySelector('[data-dir="prev"]');
    const nextBtn = root.querySelector('[data-dir="next"]');
    if (!track || !prevBtn || !nextBtn) return;

    const cards = Array.from(track.querySelectorAll('.speaker-card'));
    let activeIndex = 0;

    const getCardsPerView = () => {
      if (window.matchMedia('(max-width: 640px)').matches) return 1;
      if (window.matchMedia('(max-width: 980px)').matches) return 2;
      return 4;
    };

    const getStep = () => {
      const firstCard = cards[0];
      if (!firstCard) return 0;
      const gap = parseFloat(getComputedStyle(track).gap || '0');
      return firstCard.getBoundingClientRect().width + gap;
    };

    const updateButtons = () => {
      const cardsPerView = getCardsPerView();
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      prevBtn.disabled = activeIndex <= 0;
      nextBtn.disabled = activeIndex >= maxIndex;
      root.classList.toggle('is-static', cards.length <= cardsPerView);
    };

    const apply = () => {
      const cardsPerView = getCardsPerView();
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      activeIndex = Math.min(activeIndex, maxIndex);
      const step = getStep();
      track.style.transform = `translate3d(-${activeIndex * step}px, 0, 0)`;
      updateButtons();
    };

    prevBtn.addEventListener('click', () => {
      activeIndex = Math.max(0, activeIndex - 1);
      apply();
    });

    nextBtn.addEventListener('click', () => {
      const cardsPerView = getCardsPerView();
      const maxIndex = Math.max(0, cards.length - cardsPerView);
      activeIndex = Math.min(maxIndex, activeIndex + 1);
      apply();
    });

    window.addEventListener('resize', apply);
    apply();
  })();
</script>

<style>
