---
const editions = [
  {
    title: 'Feria Gastronómica',
    description: 'Sabores locales, chefs invitados y la mejor gastronomía de la región. Productos gourmet y experiencias culinarias únicas.',
    spots: '40 Stands',
    price: 'Desde $150',
    date: 'Agosto 2025',
    image: 'https://picsum.photos/seed/gastronomica/800/480',
    cta: 'Ver Detalles',
  },
  {
    title: 'Feria Tsáchila',
    description: 'Cultura, arte y tradiciones del pueblo Tsáchila. Arteanía, música y gastronomía ancestral en un encuentro único.',
    spots: '35 Stands',
    price: 'Desde $120',
    date: 'Noviembre 2025',
    image: 'https://picsum.photos/seed/tsachila/800/480',
    cta: 'Ver Detalles',
  },
  {
    title: 'Feria Agro',
    description: 'Productos del campo, tecnología agrícola y networking del sector. Frutas, verduras, café, cacao y más.',
    spots: '50 Stands',
    price: 'Desde $130',
    date: 'Enero 2026',
    image: 'https://picsum.photos/seed/agro/800/480',
    cta: 'Ver Detalles',
  },
];

const activities = [
  {
    title: 'Ferias Infantiles',
    description: 'Actividades para niños y familias con juegos tradicionales y entretenimiento.',
    meta: 'Entrada libre',
    subMeta: 'Todos los días',
    date: 'Durante la feria',
  },
  {
    title: 'Conferencias Técnicas',
    description: 'Charlas sobre entrepreneurship, marketing y gestión de negocios.',
    meta: 'Incluido con entrada',
    subMeta: 'Aforo limitado',
    date: 'Tarde',
  },
  {
    title: 'Networking Empresarial',
    description: 'Encuentros entre empresario y clientes para generar alianzas comerciales.',
    meta: 'Solo expositors',
    subMeta: 'Pre-registro requerido',
    date: 'Mañana',
  },
];
---

<section class="program-stage" id="tickets" aria-labelledby="program-title">
  <div class="program-shell container">
    <h2 id="program-title">3 Ferias Anuales<br />Para Descubrir Santo Domingo</h2>

    <div class="program-grid top-grid">
      {editions.map((event, index) => (
        <article class="program-card day-card" style={`--card-delay: ${index * 0.08}s;`}>
          <p class="program-date">{event.date}</p>
          <h3>{event.title}</h3>
          <img src={event.image} alt={event.title} loading="lazy" />
          <p class="program-desc">{event.description}</p>
          <a href="#registro" class="program-btn">{event.cta}</a>
          <div class="program-meta">
            <strong>{event.spots}</strong>
            <span>{event.price}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="program-grid bottom-grid">
      {activities.map((event, index) => (
        <article class="program-card evening-card" style={`--card-delay: ${0.24 + index * 0.08}s;`}>
          <p class="program-date">{event.date}</p>
          <h3>{event.title}</h3>
          <p class="program-desc">{event.description}</p>
          <div class="program-meta">
            <strong>{event.meta}</strong>
            <span>{event.subMeta}</span>
          </div>
        </article>
      ))}
    </div>

    <a href="#registro" class="invite-btn">Registrarme como Expositor</a>
  </div>
</section>

<script is:inline>
  (() => {
    const stage = document.querySelector('.program-stage');
    if (!stage) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stage.classList.add('is-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
    );

    observer.observe(stage);
  })();
</script>

<style>
.program-stage {
  position: relative;
  overflow: hidden;
  background-color: #0c140a;
  background-image: linear-gradient(180deg, #0c140a 0%, #1f2f14 44%, #324d1f 100%);
  background-size: 130% 130%;
  margin-top: 0;
  padding: 4.6rem 0 3.8rem;
  animation: program-gradient-shift 12.9s ease-in-out infinite alternate;
}

.program-stage::before {
  content: "";
  position: absolute;
  left: 50%;
  top: -140px;
  transform: translateX(-50%);
  width: min(980px, 94vw);
  height: 520px;
  background: repeating-radial-gradient(
    ellipse at 50% 0%,
    rgba(218, 227, 234, 0.12) 0 1px,
    transparent 1px 23px
  );
  opacity: 0.2;
  pointer-events: none;
}

.program-stage::after {
  content: "";
  position: absolute;
  left: 0;
  top: -1px;
  width: 100%;
  height: 80px;
  background: linear-gradient(180deg, rgba(12, 20, 10, 0.98) 0%, rgba(12, 20, 10, 0.7) 48%, rgba(12, 20, 10, 0) 100%);
  pointer-events: none;
  z-index: 1;
}

@keyframes program-gradient-shift {
  0% {
    background-position: 0% 35%;
  }

  100% {
    background-position: 100% 65%;
  }
}

.program-shell {
  position: relative;
  z-index: 2;
}

.program-shell h2 {
  margin: 0 0 1.6rem;
  text-align: center;
  text-transform: uppercase;
  line-height: 0.95;
  font-size: clamp(2rem, 4.6vw, 4rem);
  color: #f2f4f7;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-weight: 500;
}

.program-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.7rem;
}

.bottom-grid {
  margin-top: 0.45rem;
}

.program-card {
  position: relative;
  border-radius: 12px;
  padding: 1rem;
  overflow: hidden;
  opacity: 0;
  transform: translate3d(0, 20px, 0) scale(0.985);
  filter: blur(4px);
  border: 1px solid transparent;
  box-shadow: 0 14px 32px rgba(2, 8, 14, 0.16);
  will-change: transform, opacity, filter, box-shadow, border-color;
  transition:
    transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
    box-shadow 220ms ease,
    border-color 220ms ease;
}

.program-card::before {
  content: "";
  position: absolute;
  inset: -30% -10% auto;
  height: 72%;
  background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.52), rgba(255, 255, 255, 0));
  opacity: 0;
  pointer-events: none;
  transition: opacity 220ms ease;
}

.program-stage.is-visible .program-card {
  animation: premium-card-reveal 520ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  animation-delay: var(--card-delay, 0s);
}

.program-card:hover,
.program-card:focus-within {
  transform: translate3d(0, -6px, 0);
  border-color: rgba(255, 255, 255, 0.24);
  box-shadow:
    0 26px 44px rgba(1, 10, 18, 0.28),
    0 10px 20px rgba(1, 10, 18, 0.14);
}

.program-card:hover::before,
.program-card:focus-within::before {
  opacity: 0.22;
}

.day-card {
  background: #e7e7e7;
  color: #212528;
  display: grid;
  grid-template-rows: auto auto auto 1fr auto auto;
}

.day-card h3,
.evening-card h3 {
  margin: 0.32rem 0 0;
  font-size: clamp(1.24rem, 1.65vw, 1.84rem);
  line-height: 1.08;
  letter-spacing: -0.01em;
  text-wrap: balance;
  transition: transform 240ms ease;
}

.program-date {
  margin: 0;
  color: #7c8489;
  font-size: 0.92rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.program-card img {
  width: 100%;
  height: 165px;
  object-fit: cover;
  border-radius: 10px;
  margin-top: 0.7rem;
  transition: transform 260ms ease;
}

.program-desc {
  margin: 0.78rem 0 0;
  font-size: 0.96rem;
  line-height: 1.62;
  color: #3d464c;
  transition: transform 240ms ease;
}

.program-btn {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  margin-top: 0.95rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  text-decoration: none;
  color: #f9fbff;
  background: #1f2f14;
  border-radius: 999px;
  padding: 0.45rem 0.9rem;
  font-weight: 700;
  transition:
    transform 220ms ease,
    box-shadow 220ms ease;
}

.program-btn::after {
  content: "";
  position: absolute;
  left: -42%;
  top: 0;
  width: 36%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0));
  transform: skewX(-22deg);
  opacity: 0;
  pointer-events: none;
}

.program-card:hover .program-btn,
.program-card:focus-within .program-btn {
  transform: translate3d(0, -3px, 0);
  box-shadow: 0 12px 26px rgba(8, 14, 21, 0.35);
}

.program-card:hover .program-btn::after,
.program-card:focus-within .program-btn::after {
  animation: btn-sheen 380ms ease;
}

.program-btn:active {
  transform: translate3d(0, 1px, 0);
}

.program-meta {
  margin-top: 1rem;
  padding-top: 0.7rem;
  border-top: 1px dashed rgba(37, 45, 51, 0.25);
  display: grid;
  gap: 0.2rem;
}

.program-meta strong {
  font-size: 0.98rem;
  line-height: 1.35;
}

.program-meta span {
  color: #717c84;
  font-size: 0.9rem;
  line-height: 1.42;
}

.evening-card {
  background: linear-gradient(180deg, rgba(12, 20, 10, 0.98), rgba(12, 20, 10, 0.98));
  color: #f1f4f6;
  min-height: 170px;
}

.evening-card .program-desc {
  color: #cfd7dd;
}

.evening-card .program-date {
  color: #83909a;
}

.evening-card .program-meta {
  border-top-color: rgba(221, 227, 233, 0.18);
}

.evening-card .program-meta span {
  color: #aab4bc;
}

.program-card:hover h3,
.program-card:focus-within h3 {
  transform: translate3d(0, -2px, 0);
}

.program-card:hover .program-desc,
.program-card:focus-within .program-desc {
  transform: translate3d(0, -1px, 0);
}

.program-card:hover img,
.program-card:focus-within img {
  transform: scale(1.03);
}

.invite-btn {
  margin: 1.5rem auto 0;
  display: flex;
  width: fit-content;
  text-decoration: none;
  color: #f6f8fb;
  background: #1f2f14;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 999px;
  padding: 0.7rem 1.35rem;
  font-weight: 700;
}

@keyframes premium-card-reveal {
  0% {
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.985);
    filter: blur(4px);
  }

  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }
}

@keyframes btn-sheen {
  0% {
    left: -42%;
    opacity: 0;
  }

  18% {
    opacity: 1;
  }

  100% {
    left: 120%;
    opacity: 0;
  }
}

@media (max-width: 980px) {
  .program-grid {
    grid-template-columns: 1fr;
  }

  .program-card {
    padding: 1rem 0.95rem;
  }

  .program-card img {
    height: 210px;
  }

  .program-desc {
    font-size: 0.94rem;
    line-height: 1.58;
  }
}

@media (prefers-reduced-motion: reduce) {
  .program-card {
    opacity: 1;
    transform: none;
    filter: none;
    animation: none !important;
    transition: opacity 180ms ease;
  }

  .program-card::before,
  .program-card img,
  .program-card h3,
  .program-card .program-desc,
  .program-card .program-btn,
  .program-card .program-btn::after {
    transition: none !important;
    animation: none !important;
  }

  .program-card:hover,
  .program-card:focus-within,
  .program-card:hover h3,
  .program-card:focus-within h3,
  .program-card:hover .program-desc,
  .program-card:focus-within .program-desc,
  .program-card:hover img,
  .program-card:focus-within img,
  .program-card:hover .program-btn,
  .program-card:focus-within .program-btn {
    transform: none;
  }
}
</style>
