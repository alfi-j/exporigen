---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'EXPORIGEN - Ferias y Exposiciones en Santo Domingo' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="EXPORIGEN - Centro de ferias y exposiciones en Santo Domingo de los Colorados, Ecuador." />
    <meta name="theme-color" content="#B5621A" />
    <link rel="icon" type="image/png" href="/src/assets/exporigen-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>